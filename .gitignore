# =============================================================================
# .gitignore – Universelle Vorlage für alle Projekte
# =============================================================================

# ---- Betriebssystem --------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ---- IDE & Editoren --------------------------------------------------------
# JetBrains (IntelliJ, WebStorm, PyCharm, …)
.idea/
*.iws
*.iml
*.ipr
out/

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln.docstates
.vs/

# Vim / Neovim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ---- Abhängigkeiten & Build-Artefakte --------------------------------------
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.hypothesis/
.pytest_cache/
*.cover
*.py,cover
.coverage
.coverage.*
htmlcov/

# Java / Kotlin / Gradle / Maven
target/
*.class
*.jar
*.war
*.ear
*.nar
.gradle/
build/
gradle-app.setting
!gradle-wrapper.jar
.gradletasknamecache

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# Rust
/target
Cargo.lock

# Ruby / Bundler
.bundle/
vendor/bundle
*.gem
.ruby-version

# PHP / Composer
vendor/
composer.lock

# .NET / C#
bin/
obj/
*.user
*.vs/
publish/
packages/
*.nupkg
*.snupkg

# ---- Logs & Temp-Dateien ---------------------------------------------------
logs/
*.log
*.tmp
*.temp
*.bak
*.orig
*.pid
*.seed
*.pid.lock
.cache/
tmp/
temp/

# ---- Umgebungsvariablen & Geheimnisse --------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key
*.cert
*.p12
secrets/
credentials/

# ---- Test- & Coverage-Reports ----------------------------------------------
coverage/
.nyc_output/
test-results/
test-report/
junit.xml
*.lcov

# ---- Dokumentations-Build --------------------------------------------------
docs/_build/
docs/site/
site/
_site/

# ---- Docker ----------------------------------------------------------------
.docker/

# ---- Terraform -------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
